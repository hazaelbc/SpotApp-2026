# Base de datos PostgreSQL (Supabase o cualquier Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Puerto del servidor (Render lo inyecta automáticamente, no lo setees manualmente en Render)
PORT=3000

# CORS: URLs del frontend separadas por coma (e.g. tu dominio en Vercel)
ALLOWED_ORIGINS=https://tu-app.vercel.app,https://otro-dominio.com

# Entorno
NODE_ENV=production

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Firebase (solo si el backend lo usa directamente)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
